{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    'docker:enableMajor',
    'helpers:pinGitHubActionDigests',
    'github>billimek/k8s-gitops//.renovate/allowedVersions.json5',
    'github>billimek/k8s-gitops//.renovate/autoMerge.json5',
    'github>billimek/k8s-gitops//.renovate/customManagers.json5',
    'github>billimek/k8s-gitops//.renovate/grafanaDashboards.json5',
    'github>billimek/k8s-gitops//.renovate/overrides.json5',
    'github>billimek/k8s-gitops//.renovate/groups.json5',
    'github>billimek/k8s-gitops//.renovate/labels.json5',
    'github>billimek/k8s-gitops//.renovate/semanticCommits.json5',
    ':disableRateLimiting',
    ':dependencyDashboard',
    ':semanticCommits',
    ':timezone(America/New_York)',
  ],

  rebaseWhen: 'auto',
  platformAutomerge: true,
  // GHCR/OCI images (e.g. siderolabs/installer) and github-actions releases often lack a
  // releaseTimestamp; without this, Renovate's timestamp-required default marks them pending
  // forever and never opens a PR, even once minimumReleaseAge would otherwise be satisfied.
  minimumReleaseAgeBehaviour: 'timestamp-optional',

  dependencyDashboardTitle: 'Renovate Dashboard 🤖',
  suppressNotifications: [
    'prEditedNotification',
    'prIgnoreNotification',
  ],

  flux: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml$/',
      '/(^|/)setup/.+\\.ya?ml$/',
    ],
  },
  'helm-values': {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml$/',
      '/(^|/)setup/.+\\.ya?ml$/',
    ],
  },
  kubernetes: {
    managerFilePatterns: [
      '/(^|/)kubernetes/.+\\.ya?ml$/',
      '/(^|/)setup/.+\\.ya?ml$/',
    ],
  },
}
