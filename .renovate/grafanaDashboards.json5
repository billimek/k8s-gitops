{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  customDatasources: {
    "grafana-dashboards": {
      defaultRegistryUrlTemplate: "https://grafana.com/api/dashboards/{{packageName}}",
      format: "json",
      transformTemplates: ['{"releases":[{"version": $string(revision)}]}'],
    },
  },
  customManagers: [
    {
      customType: "regex",
      description: "Process Grafana dashboards",
      managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml$/"],
      matchStrings: [
        "dashboards\\/(?<depName>\\d+)\\/revisions\\/(?<currentValue>\\d+)\\/download",
      ],
      autoReplaceStringTemplate: "dashboards/{{{depName}}}/revisions/{{{newValue}}}/download",
      datasourceTemplate: "custom.grafana-dashboards",
      versioningTemplate: "regex:^(?<major>\\d+)$",
    },
  ],
  packageRules: [
    {
      addLabels: ["renovate/grafana-dashboard"],
      automerge: true,
      automergeType: "pr",
      commitMessageExtra: "({{currentVersion}} → {{newVersion}})",
      commitMessageTopic: "dashboard {{depName}}",
      matchDatasources: ["custom.grafana-dashboards"],
      matchUpdateTypes: ["major"],
      semanticCommitScope: "grafana-dashboards",
      semanticCommitType: "chore",
    },
    {
      // Dashboard 22413 migrated to dashboard.grafana.app/v2 schema at revision 7,
      // which grafana-operator cannot import via spec.url. Frozen at last classic revision (6).
      matchDatasources: ["custom.grafana-dashboards"],
      matchPackageNames: ["22413"],
      enabled: false,
    },
  ],
}
